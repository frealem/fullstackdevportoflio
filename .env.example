# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this via the Secrets panel in the AI Studio UI or hosting platform dashboard.
GEMINI_API_KEY="your-gemini-api-key"

# MONGODB_URI: Connection string for your MongoDB Atlas cloud database clusters.
# Configure this inside your hosting platform's Secrets or Env variables panel.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/portfolio_db?retryWrites=true&w=majority"

# SMTP_CONFIG: Required to dispatch real-time emails to exprefgfg@gmail.com on contact submission.
# If omitted, contact inquiries are still permanently logged in your MongoDB database and simulated cleanly.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# RESEND_CONFIG: Preferred provider for modern, reliable, real-time email deliveries.
# If configured, emails are routed via Resend API instead of SMTP.
RESEND_API_KEY="re_123456789abcdef"
RESEND_FROM="onboarding@resend.dev"

